# MongoDB
MONGODB_URI=mongodb+srv://user:password@cluster0.xxxxx.mongodb.net/lms_db?retryWrites=true&w=majority
MONGODB_DB_NAME=lms_db

# Security
SECRET_KEY=replace-with-random-64-char-hex-string
ALLOWED_HOSTS=.onrender.com,localhost,127.0.0.1


# Initial admin credentials (only used for first-time seed, not stored in code)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# Optional: seed a demo student (only used for first-time seed)
SEED_STUDENT_EMAIL=john@example.com
SEED_STUDENT_PASSWORD=student123
